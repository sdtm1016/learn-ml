 false, "text": "应用：个体化干预获益评估", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "text", "x": 60, "y": 618, "width": 300, "height": 20, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "hachure", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ap", "roundness": null, "seed": 174474, "version": 1, "versionNonce": 1221162, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "判断哪些患者最可能从强化随访、", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "text", "x": 60, "y": 636, "width": 300, "height": 20, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "hachure", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aq", "roundness": null, "seed": 174475, "version": 1, "versionNonce": 1221163, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "远程监测、健康教育中获益", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "rectangle", "x": 40, "y": 716, "width": 1120, "height": 454, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#fff4e6", "fillStyle": "hachure", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 2, "opacity": 100, "groupIds": [], "frameId": null, "index": "ar", "roundness": {"type": 3}, "seed": 397, "version": 1, "versionNonce": 530, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false}, {"type": "text", "x": 60, "y": 736, "width": 200, "height": 31, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": n