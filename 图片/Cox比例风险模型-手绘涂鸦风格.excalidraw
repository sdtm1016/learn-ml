 "strokeStyle": "dashed", "roughness": 2, "opacity": 100, "groupIds": [], "frameId": null, "index": "a7", "roundness": {"type": 3}, "seed": 500008, "version": 1, "versionNonce": 700008, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false}, {"id": "cox_title", "type": "text", "x": 300, "y": 28, "width": 620, "height": 52, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "a8", "roundness": null, "seed": 500020, "version": 1, "versionNonce": 700020, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "Cox 比例风险模型", "fontSize": 34, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 34}, {"id": "cox_sub", "type": "text", "x": 300, "y": 84, "width": 620, "height": 26, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "a9", "roundness": null, "seed": 500021, "version": 1, "versionNonce": 700021, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "生存分析金标准：预测‘事件会不会 + 何时发生’ · 手绘涂鸦风格", "fontSize": 17, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 17}, {"id": "cox_l1", "type": "text", "x": 120, "y": 156, "width": 60, "height": 20, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aa", "roundness": null, "seed": 500022, "version": 1, "versionNonce": 700022, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "S(t)", "fontSize": 13, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 13}, {"id": "cox_l2", "type": "text", "x": 126, "y": 172, "width": 40, "height": 18, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ab", "roundness": null, "seed": 500023, "version": 1, "versionNonce": 700023, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "1.0", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 12}, {"id": "cox_l3", "type": "text", "x": 130, "y": 292, "width": 34, "height": 18, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ac", "roundness": null, "seed": 500024, "version": 1, "versionNonce": 700024, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "0.5", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 12}, {"id": "cox_l4", "type": "text", "x": 138, "y": 416, "width": 30, "height": 18, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ad", "roundness": null, "seed": 500025, "version": 1, "versionNonce": 700025, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "0", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 12}, {"id": "cox_l5", "type": "text", "x": 470, "y": 430, "width": 80, "height": 18, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ae", "roundness": null, "seed": 500026, "version": 1, "versionNonce": 700026, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "时间 t →", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 12}, {"id": "cox_l6", "type": "text", "x": 180, "y": 380, "width": 360, "height": 18, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "af", "roundness": null, "seed": 500027, "version": 1, "versionNonce": 700027, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "— 生存曲线 S(t)（随时间下降）", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 12}, {"id": "cox_f1", "type": "text", "x": 600, "y": 166, "width": 560, "height": 26, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ag", "roundness": null, "seed": 500028, "version": 1, "versionNonce": 700028, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "风险函数（即时风险）", "fontSize": 18, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 18}, {"id": "cox_f2", "type": "text", "x": 600, "y": 198, "width": 560, "height": 28, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ah", "roundness": null, "seed": 500029, "version": 1, "versionNonce": 700029, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "h(t|X) = h₀(t) · exp(β₁x₁ + … + βₚxₚ)", "fontSize": 19, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 19}, {"id": "cox_f3", "type": "text", "x": 600, "y": 234, "width": 560, "height": 22, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ai", "roundness": null, "seed": 500030, "version": 1, "versionNonce": 700030, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "h₀(t)：基线风险（非参数，不假设分布形状）", "fontSize": 13, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 13}, {"id": "cox_f4", "type": "text", "x": 600, "y": 260, "width": 560, "height": 20, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aj", "roundness": null, "seed": 500031, "version": 1, "versionNonce": 700031, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "只估计系数 β，不估计 h₀(t)（半参数）", "fontSize": 12, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 12}, {"id": "cox_h1", "type": "text", "x": 600, "y": 336, "width": 560, "height": 26, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ak", "roundness": null, "seed": 500032, "version": 1, "versionNonce": 700032, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "系数 β → 风险比 HR = exp(β)", "fontSize": 18, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 18}, {"id": "cox_h2", "type": "text", "x": 600, "y": 368, "width": 560, "height": 24, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "al", "roundness": null, "seed": 500033, "version": 1, "versionNonce": 700033, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "例：β = 0.69  →  HR = 2.0", "fontSize": 17, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 17}, {"id": "cox_h3", "type": "text", "x": 600, "y": 396, "width": 560, "height": 22, "angle": 0, "strokeColor": "#e03131", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "am", "roundness": null, "seed": 500034, "version": 1, "versionNonce": 700034, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "→ 该指标使事件风险变为 2 倍", "fontSize": 15, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 15}, {"id": "cox_h4", "type": "text", "x": 600, "y": 422, "width": 560, "height": 20, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "an", "roundness": null, "seed": 500035, "version": 1, "versionNonce": 700035, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "(附 95% 置信区间，临床可直接解读)", "fontSize": 12, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 12}, {"id": "cox_kt", "type": "text", "x": 120, "y": 492, "width": 560, "height": 24, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ao", "roundness": null, "seed": 500036, "version": 1, "versionNonce": 700036, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "Cox 模型 · 关键点", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "cox_k1", "type": "text", "x": 140, "y": 526, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ap", "roundness": null, "seed": 500037, "version": 1, "versionNonce": 700037, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "① 同时建模‘是否发生 + 何时发生’", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_k2", "type": "text", "x": 140, "y": 556, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aq", "roundness": null, "seed": 500038, "version": 1, "versionNonce": 700038, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "② 能处理删失数据（失访 / 到期未发生事件）", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_k3", "type": "text", "x": 140, "y": 586, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ar", "roundness": null, "seed": 500039, "version": 1, "versionNonce": 700039, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "③ 比例风险假设：HR 不随时间变化", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_k4", "type": "text", "x": 140, "y": 616, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "as", "roundness": null, "seed": 500040, "version": 1, "versionNonce": 700040, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "④ 输出 HR + 95%CI，临床认可度高", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_k5", "type": "text", "x": 140, "y": 646, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "at", "roundness": null, "seed": 500041, "version": 1, "versionNonce": 700041, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "⑤ 半参数模型，灵活且稳健", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_mt", "type": "text", "x": 720, "y": 492, "width": 440, "height": 24, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "au", "roundness": null, "seed": 500042, "version": 1, "versionNonce": 700042, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "医学应用（随访）", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "cox_m1", "type": "text", "x": 740, "y": 528, "width": 400, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "av", "roundness": null, "seed": 500043, "version": 1, "versionNonce": 700043, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 终点事件时间预测（多久出现并发症）", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_m2", "type": "text", "x": 740, "y": 558, "width": 400, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aw", "roundness": null, "seed": 500044, "version": 1, "versionNonce": 700044, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 比较不同干预方案对生存期的影响", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "cox_m3", "type": "text", "x": 740, "y": 588, "width": 400, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ax", "roundness": null, "seed": 500045, "version": 1, "versionNonce": 700045, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 慢病预后研究的金标准", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "rectangle", "x": 40, "y": 750, "width": 1120, "height": 454, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#fff4e6", "fillStyle": "hachure", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 2, "opacity": 100, "gr