7, "version": 1, "versionNonce": 800057, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 遗忘门 f：丢掉哪些旧记忆", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_g2", "type": "text", "x": 120, "y": 510, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "az", "roundness": null, "seed": 600058, "version": 1, "versionNonce": 800058, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 输入门 i：写入哪些新记忆", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_g3", "type": "text", "x": 120, "y": 536, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b0", "roundness": null, "seed": 600059, "version": 1, "versionNonce": 800059, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 输出门 o：决定输出什么", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_g4", "type": "text", "x": 120, "y": 562, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b1", "roundness": null, "seed": 600060, "version": 1, "versionNonce": 800060, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "GRU 简化为：更新门 + 重置门（更轻量）", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_kt", "type": "text", "x": 680, "y": 452, "width": 400, "height": 24, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b2", "roundness": null, "seed": 600061, "version": 1, "versionNonce": 800061, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "LSTM/GRU · 关键点", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "lstm_k1", "type": "text", "x": 700, "y": 484, "width": 360, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b3", "roundness": null, "seed": 600062, "version": 1, "versionNonce": 800062, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "① 专门处理时序 / 序列数据", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_k2", "type": "text", "x": 700, "y": 510, "width": 360, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b4", "roundness": null, "seed": 600063, "version": 1, "versionNonce": 800063, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "② 能记住长期依赖关系", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_k3", "type": "text", "x": 700, "y": 536, "width": 360, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b5", "roundness": null, "seed": 600064, "version": 1, "versionNonce": 800064, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "③ 比静态模型更懂‘变化趋势’", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_k4", "type": "text", "x": 700, "y": 562, "width": 360, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b6", "roundness": null, "seed": 600065, "version": 1, "versionNonce": 800065, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "④ 需足量连续数据，训练成本高", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_mt", "type": "text", "x": 100, "y": 642, "width": 980, "height": 24, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b7", "roundness": null, "seed": 600066, "version": 1, "versionNonce": 800066, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "医学应用（随访）", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "lstm_m1", "type": "text", "x": 130, "y": 674, "width": 930, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b8", "roundness": null, "seed": 600067, "version": 1, "versionNonce": 800067, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 动态指标预测：依过去血糖/血压波动，预判未来趋势", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "lstm_m2", "type": "text", "x": 130, "y": 700, "width": 930, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b9", "roundness": null, "seed": 600068, "version": 1, "versionNonce": 800068, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 早期恶化预警（如‘近 3 月血糖持续走高 → 失控风险高’）", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "rectangle", "x": 40, "y": 805, "width": 1120, "height": 454, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#fff4e6", "fillStyle": "hachure", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 2, "opacity": 100, "groupIds": [], "frameId": null, "index": "ba", "roundness": {"type": 3}, "seed": 644, "version": 1, "versionNonce": 853, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false}, {"type": "text", "x": 60, "y": 825, "width": 200, "height": 31, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bb", "roundness": null, "seed": 670, "version": 1, "versionNonce": 870, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "通俗解读", "fontSize": 24, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 24}, {"type": "line", "x": 60, "y": 861, "width": 1080, "height": 0, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bc", "roundness": null, "seed": 696, "version": 1, "versionNonce": 921, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "points": [[0, 0], [1080, 0]], "startBinding": null, "endBinding": null}, {"type": "text", "x": 60, "y": 871, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bd", "roundness": null, "seed": 722, "version": 1, "versionNonce": 938, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 原理", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 893, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "be", "roundness": null, "seed": 735, "version": 1, "versionNonce": 955, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 一种带'记忆门'的神经网络，能记住指标随时间的变化模式（如血糖逐月升高、波动变大），用来预判未来。", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 927, "width": 160, "height": 22, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bf", "roundness": null, "seed": 748, "version": 1, "versionNonce": 972, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 特点", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 949, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bg", "roundness": null, "seed": 761, "version": 1, "versionNonce": 989, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 擅长捕捉长期时序趋势和波动", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 973, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bh", "roundness": null, "seed": 774, "version": 1, "versionNonce": 1006, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 动态预警能力强", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 997, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bi", "roundness": null, "seed": 787, "version": 1, "versionNonce": 1023, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 黑盒，需大量连续数据，训练成本高", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1031, "width": 160, "height": 22, "angle": 0, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness