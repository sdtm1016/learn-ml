 false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "F(x) = F₀ + η·h₁(x) + η·h₂(x) + …  (学习率 η 防过拟合)", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"type": "text", "x": 60, "y": 640, "width": 300, "height": 20, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "hachure", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ap", "roundness": null, "seed": 859371, "version": 1, "versionNonce": 6015441, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "应用：慢病高风险预警、病情进展预测", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "text", "x": 60, "y": 658, "width": 300, "height": 20, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "hachure", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aq", "roundness": null, "seed": 859372, "version": 1, "versionNonce": 6015442, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "精度高、能处理缺失值，", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "text", "x": 60, "y": 676, "width": 300, "height": 20, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "hachure", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ar", "roundness": null, "seed": 859373, "version": 1, "versionNonce": 6015443, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "是工业随访预测的顶流方案", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "rectangle", "x": 40, "y": 756, "width": 1120, "height": 478, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#fff4e6", "fillStyle": "hachure", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 2, "opacity": 100, "groupIds": [], "frameId": null, "index": "as", "roundness": {"type": 3}, "seed": 410, "version": 1, "versionNonce": 547, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false}, {"type": "text", "x": 60, "y": 776, "width": 200, "height": 31, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "at", "roundness": null, "seed": 436, "version": 1, "versionNonce": 564, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "通俗解读", "fontSize": 24, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 24}, {"type": "line", "x": 60, "y": 812, "width": 1080, "height": 0, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "au", "roundness": null, "seed": 462, "version": 1, "versionNonce": 615, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "points": [[0, 0], [1080, 0]], "startBinding": null, "endBinding": null}, {"type": "text", "x": 60, "y": 822, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "av", "roundness": null, "seed": 488, "version": 1, "versionNonce": 632, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 原理", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 844, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aw", "roundness": null, "seed": 501, "version": 1, "versionNonce": 649, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 先给一个初始预测，然后一棵接一棵地'纠正上一棵的错误'，每棵新树专门去拟合前面没预测准的部分。", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 878, "width": 160, "height": 22, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ax", "roundness": null, "seed": 514, "version": 1, "versionNonce": 666, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 特点", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 900, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ay", "roundness": null, "seed": 527, "version": 1, "versionNonce": 683, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 精度通常最高，是工业预测顶流", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 924, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "az", "roundness": null, "seed": 540, "version": 1, "versionNonce": 700, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 擅长捕捉复杂的非线性组合关系", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 948, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b0", "roundness": null, "seed": 553, "version": 1, "versionNonce": 717, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 能较好处理随访常见的缺失值", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 972, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b1", "roundness": null, "seed": 566, "version": 1, "versionNonce": 734, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 黑盒，结果难直接解释（需配 SHAP）", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1006, "width": 160, "height": 22, "angle": 0, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b2", "roundness": null, "seed": 579, "version": 1, "versionNonce": 751, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1028, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b3", "roundness": null, "seed": 592, "version": 1, "versionNonce": 768, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 高风险预警、病情进展预测", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1052, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b4", "roundness": null, "seed": 605, "version": 1, "versionNonce": 785, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 干预效果预判", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1076, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b5", "roundness": null, "seed": 618, "version": 1, "versionNonce": 802, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 中/大样本的慢病预测系统", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1110, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e03131", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b6", "roundness": null, "seed": 631, "version": 1, "versionNonce": 819, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 不适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1132, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b7", "roundness": null, "seed": 644, "version": 1, "versionNonce": 836, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 样本极少的小项目", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1156, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b8", "roundness": null, "seed": 657, "version": 1, "versionNonce": 853, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 必须 100% 解释清楚的报表", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1180, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b9", "roundness": null, "seed": 670, "version": 1, "versionNonce": 870, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 对训练成本敏感的终端", "fontSize": 15, "fontFamily": 1, "textAli