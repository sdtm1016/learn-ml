, "version": 1, "versionNonce": 989, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1018, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bh", "roundness": null, "seed": 774, "version": 1, "versionNonce": 1006, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 预后评估、风险分层", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1042, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bi", "roundness": null, "seed": 787, "version": 1, "versionNonce": 1023, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 关键影响因素筛选", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1066, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bj", "roundness": null, "seed": 800, "version": 1, "versionNonce": 1040, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 中/大样本稳健建模", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1100, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e03131", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bk", "roundness": null, "seed": 813, "version": 1, "versionNonce": 1057, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 不适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1122, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bl", "roundness": null, "seed": 826, "version": 1, "versionNonce": 1074, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 需要精确系数解释的场景", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1146, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bm", "roundness": null, "seed": 839, "version": 1, "versionNonce": 1091, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 超高维稀疏数据", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1170, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bn", "roundness": null, "seed": 852, "version": 1, "versionNonce": 1108, "i