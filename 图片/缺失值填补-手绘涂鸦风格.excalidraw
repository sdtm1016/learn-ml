ndness": null, "seed": 1203, "version": 1, "versionNonce": 1567, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 用相似患者（KNN）或链式方程（MICE）估计并补上漏填/失访的指标，避免直接删数据造成样本浪费。", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 838, "width": 160, "height": 22, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "cf", "roundness": null, "seed": 1216, "version": 1, "versionNonce": 1584, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 特点", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 860, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "cg", "roundness": null, "seed": 1229, "version": 1, "versionNonce": 1601, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 减少样本浪费", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 884, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ch", "roundness": null, "seed": 1242, "version": 1, "versionNonce": 1618, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 更贴近真实世界数据", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 908, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ci", "roundness": null, "seed": 1255, "version": 1, "versionNonce": 1635, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 填补不当会引入偏倚", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 942, "width": 160, "height": 22, "angle": 0, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "cj", "roundness": null, "seed": 1268, "version": 1, "versionNonce": 1652, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 964, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ck", "roundness": null, "seed": 1281, "version": 1, "versionNonce": 1669, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 随访漏填、检查缺失、失访的缺口", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 988, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "cl", "