: "top", "baseline": 24}, {"type": "line", "x": 60, "y": 876, "width": 1080, "height": 0, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b9", "roundness": null, "seed": 657, "version": 1, "versionNonce": 870, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "points": [[0, 0], [1080, 0]], "startBinding": null, "endBinding": null}, {"type": "text", "x": 60, "y": 886, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ba", "roundness": null, "seed": 683, "version": 1, "versionNonce": 887, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 原理", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 908, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bb", "roundness": null, "seed": 696, "version": 1, "versionNonce": 904, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 事先定好分几类，算法反复调整'每个类的中心'，把患者分到离自己最近的中心那一类。", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 942, "width": 160, "height": 22, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bc", "roundness": null, "seed": 709, "version": 1, "versionNonce": 921, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 特点", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 964, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bd", "roundness": null, "seed": 722, "version": 1, "versionNonce": 938, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 无需标注数据，自动人群分层", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 988, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "be", "roundness": null, "seed": 735, "version": 1, "versionNonce": 955, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 简单高效、适合批量管理", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1012, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bf", "roundness": null, "seed": 748, "version": 1, "versionNonce": 972, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 需人工指定类别数，受异常点干扰", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1046, "width": 160, "height": 22, "angle": 0, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bg", "roundness": null, "seed": 761, "version": 1, "versionNonce": 989, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1068, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bh", "roundness": null, "seed": 774, "version": 1, "versionNonce": 1006, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 患者亚组分型、精细化随访分组", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1092, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bi", "roundness": null, "seed": 787, "version": 1, "versionNonce": 1023, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 设计不同随访频率/方案", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1116, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bj", "roundness": null, "seed": 800, "version": 1, "versionNonce": 1040, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 海量患者的批量分层", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1150, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e03131", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bk", "roundness": null, "seed": 813, "version": 1, "versionNonce": 1057, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 不适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1172, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bl", "roundness": null, "seed": 826, "version": 1, "versionNonce": 1074, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 类别形状复杂/非球形分布", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1196, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bm", "roundness": null, "seed": 839, "version": 1, "versionNonce": 1091, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 不知道该分几类时", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1220, "width": 1056, "height