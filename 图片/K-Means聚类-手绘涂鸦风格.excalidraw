 "text": "迭代", "fontSize": 13, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 13}, {"id": "km_star1", "type": "text", "x": 623, "y": 222, "width": 24, "height": 26, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "as", "roundness": null, "seed": 700045, "version": 1, "versionNonce": 900045, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "★", "fontSize": 22, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 22}, {"id": "km_star2", "type": "text", "x": 808, "y": 217, "width": 24, "height": 26, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "at", "roundness": null, "seed": 700046, "version": 1, "versionNonce": 900046, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "★", "fontSize": 22, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 22}, {"id": "km_star3", "type": "text", "x": 718, "y": 342, "width": 24, "height": 26, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "au", "roundness": null, "seed": 700047, "version": 1, "versionNonce": 900047, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "★", "fontSize": 22, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 22}, {"id": "km_st", "type": "text", "x": 120, "y": 462, "width": 940, "height": 24, "angle": 0, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "av", "roundness": null, "seed": 700048, "version": 1, "versionNonce": 900048, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "迭代过程（无监督学习）", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "km_s1", "type": "text", "x": 160, "y": 494, "width": 880, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "aw", "roundness": null, "seed": 700049, "version": 1, "versionNonce": 900049, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "① 随机选 K 个初始质心      ② 每个点归入最近的质心 → 形成 K 簇", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_s2", "type": "text", "x": 160, "y": 522, "width": 880, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ax", "roundness": null, "seed": 700050, "version": 1, "versionNonce": 900050, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "③ 把每簇质心更新为该簇点的均值      ④ 重复 ②③，直到质心不再移动（收敛）", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_kt", "type": "text", "x": 120, "y": 602, "width": 560, "height": 24, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ay", "roundness": null, "seed": 700051, "version": 1, "versionNonce": 900051, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "K-Means · 关键点", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "km_k1", "type": "text", "x": 140, "y": 634, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "az", "roundness": null, "seed": 700052, "version": 1, "versionNonce": 900052, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "① 无需标签，自动发现人群结构", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_k2", "type": "text", "x": 140, "y": 660, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b0", "roundness": null, "seed": 700053, "version": 1, "versionNonce": 900053, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "② 需人工指定簇数 K", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_k3", "type": "text", "x": 140, "y": 686, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b1", "roundness": null, "seed": 700054, "version": 1, "versionNonce": 900054, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "③ 选 K：肘部法则 / 轮廓系数", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_k4", "type": "text", "x": 140, "y": 712, "width": 520, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b2", "roundness": null, "seed": 700055, "version": 1, "versionNonce": 900055, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "④ 对初始质心敏感，需先标准化", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_mt", "type": "text", "x": 700, "y": 602, "width": 360, "height": 24, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b3", "roundness": null, "seed": 700056, "version": 1, "versionNonce": 900056, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "医学应用（随访）", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "km_m1", "type": "text", "x": 720, "y": 636, "width": 320, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b4", "roundness": null, "seed": 700057, "version": 1, "versionNonce": 900057, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 患者亚组分型", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "km_m2", "type": "text", "x": 720, "y": 662, "width": 320, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "str