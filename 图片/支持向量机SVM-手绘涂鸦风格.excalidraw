ull, "index": "ax", "roundness": null, "seed": 1000034, "version": 1, "versionNonce": 1050034, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 线性核  K(x,z)=xᵀz", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "svm_ker2", "type": "text", "x": 778, "y": 350, "width": 390, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "ay", "roundness": null, "seed": 1000035, "version": 1, "versionNonce": 1050035, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 多项式核  K=(xᵀz+1)^d", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "svm_ker3", "type": "text", "x": 778, "y": 376, "width": 390, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "az", "roundness": null, "seed": 1000036, "version": 1, "versionNonce": 1050036, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• RBF 高斯核  K=exp(−γ‖x−z‖²)", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "svm_ker4", "type": "text", "x": 778, "y": 400, "width": 390, "height": 20, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b0", "roundness": null, "seed": 1000037, "version": 1, "versionNonce": 1050037, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, 