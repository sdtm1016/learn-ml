r": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b2", "roundness": null, "seed": 900039, "version": 1, "versionNonce": 950039, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "① “朴素”= 各特征条件独立假设", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "nb_k2", "type": "text", "x": 130, "y": 680, "width": 530, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b3", "roundness": null, "seed": 900040, "version": 1, "versionNonce": 950040, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "② 训练快：只统计频率/均值方差", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "nb_k3", "type": "text", "x": 130, "y": 706, "width": 530, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b4", "roundness": null, "seed": 900041, "version": 1, "versionNonce": 950041, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "③ 对小样本、高维稀疏文本稳健", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "nb_k4", "type": "text", "x": 130, "y": 732, "width": 530, "height": 22, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b5", "roundness": null, "seed": 900042, "version": 1, "versionNonce": 950042, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "④ 拉普拉斯平滑防零概率", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "nb_mt", "type": "text", "x": 700, "y": 616, "width": 470, "height": 24, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b6", "roundness": null, "seed": 900043, "version": 1, "versionNonce": 950043, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "医学应用（慢病随访）", "fontSize": 16, "fontFamily": 1, "textAlign": "center", "verticalAlign": "middle", "baseline": 16}, {"id": "nb_m1", "type": "text", "x": 710, "y": 648, "width": 450, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b7", "roundness": null, "seed": 900044, "version": 1, "versionNonce": 950044, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 疾病筛查：据症状/检验快速分类", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "nb_m2", "type": "text", "x": 710, "y": 674, "width": 450, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b8", "roundness": null, "seed": 900045, "version": 1, "versionNonce": 950045, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 随访优先级：高失访风险患者预警", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"id": "nb_m3", "type": "text", "x": 710, "y": 700, "width": 450, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "b9", "roundness": null, "seed": 900046, "version": 1, "versionNonce": 950046, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "• 可解释：各特征对后验的贡献清晰", "fontSize": 14, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 14}, {"type": "rectangle", "x": 40, "y": 844, "width": 1120, "height": 454, "angle": 0, "strokeColor": "#495057", "backgroundColor": "#fff4e6", "fillStyle": "hachure", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 2, "opacity": 100, "groupIds": [], "frameId": null, "index": "ba", "roundness": {"type": 3}, "seed": 644, "version": 1, "versionNonce": 853, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false}, {"type": "text", "x": 60, "y": 864, "width": 200, "height": 31, "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bb", "roundness": null, "seed": 670, "version": 1, "versionNonce": 870, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "通俗解读", "fontSize": 24, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 24}, {"type": "line", "x": 60, "y": 900, "width": 1080, "height": 0, "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bc", "roundness": null, "seed": 696, "version": 1, "versionNonce": 921, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "points": [[0, 0], [1080, 0]], "startBinding": null, "endBinding": null}, {"type": "text", "x": 60, "y": 910, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e8590c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bd", "roundness": null, "seed": 722, "version": 1, "versionNonce": 938, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 原理", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 932, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "be", "roundness": null, "seed": 735, "version": 1, "versionNonce": 955, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 基于贝叶斯公式算概率，并假设各指标'相互独立'，把它们的贡献乘起来做判断。", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 966, "width": 160, "height": 22, "angle": 0, "strokeColor": "#7048e8", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bf", "roundness": null, "seed": 748, "version": 1, "versionNonce": 972, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 特点", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 988, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bg", "roundness": null, "seed": 761, "version": 1, "versionNonce": 989, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 计算极快、资源占用极小", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1012, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bh", "roundness": null, "seed": 774, "version": 1, "versionNonce": 1006, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 适合基层/边缘终端", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1036, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bi", "roundness": null, "seed": 787, "version": 1, "versionNonce": 1023, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 假设过强，复杂场景精度偏低", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1070, "width": 160, "height": 22, "angle": 0, "strokeColor": "#2f9e44", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bj", "roundness": null, "seed": 800, "version": 1, "versionNonce": 1040, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1092, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bk", "roundness": null, "seed": 813, "version": 1, "versionNonce": 1057, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 基层快速初筛、轻量化预警", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1116, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bl", "roundness": null, "seed": 826, "version": 1, "versionNonce": 1074, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 文本初步分类", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1140, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bm", "roundness": null, "seed": 839, "version": 1, "versionNonce": 1091, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 样本不多但要快速出结果", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 60, "y": 1174, "width": 160, "height": 22, "angle": 0, "strokeColor": "#e03131", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bn", "roundness": null, "seed": 852, "version": 1, "versionNonce": 1108, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "■ 不适用", "fontSize": 17, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 17}, {"type": "text", "x": 84, "y": 1196, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bo", "roundness": null, "seed": 865, "version": 1, "versionNonce": 1125, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 指标之间高度相关的复杂场景", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1220, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bp", "roundness": null, "seed": 878, "version": 1, "versionNonce": 1142, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 追求高精度的核心预测", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "baseline": 15}, {"type": "text", "x": 84, "y": 1244, "width": 1056, "height": 19, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1, "opacity": 100, "groupIds": [], "frameId": null, "index": "bq", "roundness": null, "seed": 891, "version": 1, "versionNonce": 1159, "isDeleted": false, "boundElements": null, "updated": 1768000000000, "link": null, "locked": false, "text": "· 需要精确概率校准的场合"